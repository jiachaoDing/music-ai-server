generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id        String   @id @default(cuid())
  title     String
  style     String
  prompt    String
  status    String   @default("ready")
  audioUrl  String?
  lyric     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("songs")
}
